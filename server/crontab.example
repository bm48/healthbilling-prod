# Tab backups: 09:00 and 21:00 US Pacific (America/Los_Angeles, includes PDT/PST).
# Install: copy lines below into `crontab -e` on the VPS (adjust BASE and secret).
#
# Requires BACKUP_CRON_SECRET in server/.env (same value as CRON_SECRET here).

CRON_TZ=America/Los_Angeles
BACKUP_SECRET='replace-with-same-value-as-BACKUP_CRON_SECRET-in-env'
BASE='http://127.0.0.1:4000'

0 9,21 * * * curl -sS -X POST "$BASE/api/cron/backup-ar" -H "Content-Type: application/json" -d "{\"cron_secret\":\"$BACKUP_SECRET\"}" >> /var/log/health-billing-backup.log 2>&1
0 9,21 * * * curl -sS -X POST "$BASE/api/cron/backup-patients" -H "Content-Type: application/json" -d "{\"cron_secret\":\"$BACKUP_SECRET\"}" >> /var/log/health-billing-backup.log 2>&1
0 9,21 * * * curl -sS -X POST "$BASE/api/cron/backup-provider-pay" -H "Content-Type: application/json" -d "{\"cron_secret\":\"$BACKUP_SECRET\"}" >> /var/log/health-billing-backup.log 2>&1
0 9,21 * * * curl -sS -X POST "$BASE/api/cron/backup-provider-sheets" -H "Content-Type: application/json" -d "{\"cron_secret\":\"$BACKUP_SECRET\"}" >> /var/log/health-billing-backup.log 2>&1
