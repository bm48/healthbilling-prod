# =============================================================================
# Monorepo root `.env` — loaded by Vite (from repo root via client/vite.config) and by the API server
# =============================================================================
# Optional. Leave unset in local dev to use same-origin `/api/*` (Vite proxies to the Node server).
# Set in production if the API is on another origin, e.g. https://api.yourdomain.com
# VITE_API_BASE_URL=

# Used in invite emails and some links; defaults to window.location.origin in the app when unset.
# VITE_APP_ORIGIN=http://localhost:5173

# =============================================================================
# API server (Node) — copy these to `.env` in the project root and/or `server/.env`
# =============================================================================
PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/amerbilling
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-24-chars
JWT_REFRESH_SECRET=change-me-another-long-random-string-min-24-chars
FRONTEND_ORIGIN=http://localhost:5173

# Contact form destination inbox
CONTACT_TO_EMAIL=admin@amerbilling.com

# Optional: Gmail SMTP for contact form + invite emails (use an App Password, not your normal password)
# GMAIL_USER=
# GMAIL_APP_PASSWORD=

# Optional: override SMTP endpoint (default smtp.gmail.com:465 with implicit TLS). Use if you see ETIMEDOUT to a private IP
# (corporate DNS/relay) or outbound SMTP is blocked — point to your org relay or a provider that allows your network.
# SMTP_HOST=smtp-relay.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# For STARTTLS on port 587: SMTP_PORT=587 and SMTP_SECURE=false

# =============================================================================
# Vercel `api/*` proxies only — if you deploy the static app to Vercel and the API elsewhere
# =============================================================================
# API_BASE_URL=https://your-node-api.example.com
